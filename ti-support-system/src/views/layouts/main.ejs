<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title><%= title || 'Allservices' %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="app-container">

        <aside class="sidebar">
            <h2>Allservices</h2>

            <ul>
                <li><a href="/dashboard">📊 Dashboard</a></li>
                <li><a href="/usuarios">👥 Usuários</a></li>

                <% if (user && user.role === 'admin') { %>
                    <li><a href="/leads">💼 Leads</a></li>
                <% } %>

                <li><a href="/clientes">🧑 Clientes</a></li>

                <li><a href="/dispositivos">📱 Dispositivos</a></li>
                <li><a href="/ordens">🛠️ Ordens de Serviço</a></li>
                <li><a href="/estoque">📦 Estoque</a></li>
                <li><a href="/financeiro">💰 Financeiro</a></li>
                <li><a href="/relatorios">📈 Relatórios</a></li>

                <% if (user && user.role === 'admin') { %>
                    <li><a href="/admin">⚙️ Administração</a></li>
                <% } %>

                <li style="margin-top:30px; border-top:1px solid rgba(255,255,255,0.1); padding-top:15px;">
                    <a href="/auth/logout">🚪 Sair</a>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <h1><%= title %></h1>
                <div class="user-info">
                    <span><%= user ? user.name : '' %></span>
                </div>
            </header>

            <section class="content">
                <%- body %>
            </section>
        </main>

    </div>

    <script src="/js/main.js"></script>
</body>
</html>
