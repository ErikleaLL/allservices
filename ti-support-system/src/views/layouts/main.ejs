<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Allservices' %></title>
    
    <!-- Fontes premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
    
    <link rel="stylesheet" href="/css/style.css">

    <!-- 🎯 SCRIPT INICIAL DE TEMA (evita flash) -->
    <script>
        (function() {
            const temaSalvo = localStorage.getItem('allservices-tema');
            if (temaSalvo === 'claro') {
                document.documentElement.classList.add('tema-claro-pre');
            }
        })();
    </script>
    <style>
        html.tema-claro-pre body { background: #f4f6f9; color: #0f172a; }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleMenu()"></div>

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon"><i class="ti ti-bolt"></i></div>
                <div class="logo-text">Allservices</div>
            </div>

            <ul>
                <li><a href="/dashboard"><i class="ti ti-layout-dashboard"></i> Dashboard</a></li>
                <li><a href="/usuarios"><i class="ti ti-users"></i> Usuários</a></li>
                <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                    <li><a href="/leads"><i class="ti ti-target-arrow"></i> Leads</a></li>
                <% } %>
                <li><a href="/clientes"><i class="ti ti-user-circle"></i> Clientes</a></li>
                <li><a href="/dispositivos"><i class="ti ti-device-laptop"></i> Dispositivos</a></li>
                
                <div style="height: 1px; background: rgba(255,255,255,0.05); margin: 15px 10px;"></div>

                <li><a href="/ordens"><i class="ti ti-tools"></i> Ordens de Serviço</a></li>
                <li><a href="/estoque"><i class="ti ti-package"></i> Estoque</a></li>
                <li><a href="/financeiro"><i class="ti ti-cash"></i> Financeiro</a></li>
                
                <div style="height: 1px; background: rgba(255,255,255,0.05); margin: 15px 10px;"></div>

                <li><a href="/admin"><i class="ti ti-settings"></i> Administração</a></li>
                <li><a href="/auth/logout"><i class="ti ti-logout"></i> Sair</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div style="display:flex; align-items:center; gap:12px;">
                    <button class="menu-toggle" onclick="toggleMenu()">
                        <i class="ti ti-menu-2"></i>
                    </button>
                    <h1><%= typeof title !== 'undefined' ? title : 'Allservices' %></h1>
                </div>
                <div style="display:flex; align-items:center; gap:12px;">
                    
                    <button class="theme-toggle" onclick="trocarTema()" title="Trocar tema">
                        <i class="ti ti-moon icone-lua"></i>
                        <i class="ti ti-sun icone-sol"></i>
                    </button>

                    <div class="user-info">
                        <span><%= typeof user !== 'undefined' && user ? user.name : 'Admin' %></span>
                    </div>
                </div>
            </header>

            <%- body %>
        </main>
    </div>

    <script>
        (function aplicarTemaInicial() {
            const tema = localStorage.getItem('allservices-tema') || 'escuro';
            if (tema === 'claro') {
                document.body.classList.add('tema-claro');
            }
            document.documentElement.classList.remove('tema-claro-pre');
        })();

        function trocarTema() {
            const ehClaro = document.body.classList.toggle('tema-claro');
            localStorage.setItem('allservices-tema', ehClaro ? 'claro' : 'escuro');
        }

        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }
        
        const path = window.location.pathname;
        document.querySelectorAll('.sidebar a').forEach(link => {
            const href = link.getAttribute('href');
            if (href && href !== '/' && path.startsWith(href)) {
                link.classList.add('active');
            }
        });
    </script>
</body>
</html>
