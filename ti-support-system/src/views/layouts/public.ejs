<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0f172a">

    <!-- Fontes premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

    <link rel="stylesheet" href="/css/public.css">
    
    <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body>

    <header class="navbar">
        <div class="container nav-container">
            <a href="/" class="logo">
                <span class="logo-icon">⚡</span>
                <span class="logo-text">All<strong>services</strong></span>
            </a>

            <button class="nav-toggle" id="navToggle" aria-label="Menu">☰</button>

            <nav class="nav-menu" id="navMenu">
                <a href="/">Início</a>
                <a href="/funcionalidades">Funcionalidades</a>
                <a href="/planos">Planos</a>
                <a href="/sobre">Sobre</a>
                <a href="/contato">Contato</a>

                <div class="nav-actions-mobile">
                    <a href="/auth/login" class="btn-login">Entrar</a>
                    <a href="/contato" class="btn-cta">Quero conhecer</a>
                </div>
            </nav>

            <div class="nav-actions">
                <a href="/auth/login" class="btn-login">Entrar</a>
                <a href="/contato" class="btn-cta">Quero conhecer</a>
            </div>
        </div>
    </header>

    <main>
        <%- body %>
    </main>

    <footer class="footer">
        <div class="container footer-container">
            <div class="footer-col">
                <h3 class="footer-logo">⚡ All<strong>services</strong></h3>
                <p>Manutenção inteligente, gestão simples.</p>
                <p class="footer-tag">A plataforma de TI do futuro.</p>
            </div>

            <div class="footer-col">
                <h4>Plataforma</h4>
                <ul>
                    <li><a href="/funcionalidades">Funcionalidades</a></li>
                    <li><a href="/planos">Planos</a></li>
                    <li><a href="/sobre">Sobre nós</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Soluções</h4>
                <ul>
                    <li>Ordem de Serviço Digital</li>
                    <li>Garantia Rastreável</li>
                    <li>IA de Triagem</li>
                    <li>Logística Reversa Verde</li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Contato</h4>
                <ul>
                    <li>📧 contato@allservices.com</li>
                    <li>📱 (00) 00000-0000</li>
                    <li><a href="/auth/login">Área restrita</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; <%= new Date().getFullYear() %> Allservices • Todos os direitos reservados</p>
        </div>
    </footer>

    <script>
        (function() {
            const navToggle = document.getElementById('navToggle');
            const navMenu = document.getElementById('navMenu');

            if (navToggle && navMenu) {
                navToggle.addEventListener('click', function() {
                    navMenu.classList.toggle('active');
                    navToggle.textContent = navMenu.classList.contains('active') ? '✕' : '☰';
                });

                navMenu.querySelectorAll('a').forEach(link => {
                    link.addEventListener('click', () => {
                        navMenu.classList.remove('active');
                        navToggle.textContent = '☰';
                    });
                });
            }
        })();
    </script>

</body>
</html>
