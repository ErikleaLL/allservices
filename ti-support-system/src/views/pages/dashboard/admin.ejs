
<!-- ===== ESTATÍSTICAS REAIS ===== -->
<div class="stats-grid">

    <div class="stat">
        <div class="stat-label">
            <i class="ti ti-cash" style="color:#4ade80;"></i> Receita do mês
        </div>
        <div class="stat-value" style="color:#4ade80;">
            R$ <%= stats.receitaMes.toFixed(2).replace('.', ',') %>
        </div>
        <div style="font-size:11.5px; color:#94a3b8; margin-top:4px;">
            Saldo do mês: 
            <strong style="color: <%= stats.saldoMes >= 0 ? '#4ade80' : '#f87171' %>;">
                R$ <%= stats.saldoMes.toFixed(2).replace('.', ',') %>
            </strong>
        </div>
    </div>

    <div class="stat">
        <div class="stat-label">
            <i class="ti ti-tools" style="color:#fbbf24;"></i> OS abertas
        </div>
        <div class="stat-value" style="color:#fbbf24;">
            <%= stats.osAbertas %>
        </div>
        <div style="font-size:11.5px; color:#94a3b8; margin-top:4px;">
            de <%= stats.totalOS %> total(is)
        </div>
    </div>

    <div class="stat">
        <div class="stat-label">
            <i class="ti ti-users" style="color:#60a5fa;"></i> Clientes ativos
        </div>
        <div class="stat-value" style="color:#60a5fa;">
            <%= stats.totalClientes %>
        </div>
        <div style="font-size:11.5px; color:#94a3b8; margin-top:4px;">
            <%= stats.totalLeads %> lead(s) capturado(s)
        </div>
    </div>

    <div class="stat">
        <div class="stat-label">
            <i class="ti ti-package" style="color:#a78bfa;"></i> Itens no estoque
        </div>
        <div class="stat-value" style="color:#a78bfa;">
            <%= stats.totalEstoque %>
        </div>
        <div style="font-size:11.5px; color:#94a3b8; margin-top:4px;">
            valor: R$ <%= (stats.estoqueValor || 0).toFixed(2).replace('.', ',') %>
        </div>
    </div>

</div>

<!-- INDICADORES SECUNDÁRIOS -->
<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:12px; margin: 0 30px 26px;">

    <div style="background: rgba(74,222,128,0.05); border: 0.5px solid rgba(74,222,128,0.2); border-radius:10px; padding:14px 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div style="font-size:10px; text-transform:uppercase; color:#94a3b8; letter-spacing:1px; font-weight:600;">A receber</div>
                <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:700; color:#4ade80; margin-top:4px;">
                    R$ <%= stats.aReceber.toFixed(2).replace('.', ',') %>
                </div>
            </div>
            <i class="ti ti-arrow-up-right" style="font-size:24px; color:#4ade80; opacity:0.4;"></i>
        </div>
    </div>

    <div style="background: rgba(248,113,113,0.05); border: 0.5px solid rgba(248,113,113,0.2); border-radius:10px; padding:14px 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div style="font-size:10px; text-transform:uppercase; color:#94a3b8; letter-spacing:1px; font-weight:600;">A pagar</div>
                <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:700; color:#f87171; margin-top:4px;">
                    R$ <%= stats.aPagar.toFixed(2).replace('.', ',') %>
                </div>
            </div>
            <i class="ti ti-arrow-down-right" style="font-size:24px; color:#f87171; opacity:0.4;"></i>
        </div>
    </div>

    <div style="background: rgba(124,58,237,0.05); border: 0.5px solid rgba(124,58,237,0.2); border-radius:10px; padding:14px 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div style="font-size:10px; text-transform:uppercase; color:#94a3b8; letter-spacing:1px; font-weight:600;">Dispositivos ativos</div>
                <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:700; color:#a78bfa; margin-top:4px;">
                    <%= stats.dispositivosAtivos %>
                </div>
            </div>
            <i class="ti ti-device-laptop" style="font-size:24px; color:#a78bfa; opacity:0.4;"></i>
        </div>
    </div>

    <div style="background: rgba(96,165,250,0.05); border: 0.5px solid rgba(96,165,250,0.2); border-radius:10px; padding:14px 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div style="font-size:10px; text-transform:uppercase; color:#94a3b8; letter-spacing:1px; font-weight:600;">Usuários</div>
                <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:700; color:#60a5fa; margin-top:4px;">
                    <%= stats.totalUsuarios %>
                </div>
            </div>
            <i class="ti ti-shield-check" style="font-size:24px; color:#60a5fa; opacity:0.4;"></i>
        </div>
    </div>

</div>

<!-- TÍTULO MÓDULOS -->
<div style="margin: 0 30px 14px; font-family:'Syne',sans-serif; font-size:13px; font-weight:600; color:rgba(255,255,255,0.55); text-transform:uppercase; letter-spacing:1px;">
    Acesso rápido
</div>

<!-- CARDS DE MÓDULOS -->
<div class="modules-grid">

    <a href="/usuarios" class="module-card purple" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(124,58,237,0.15); color:#a78bfa;">
            <i class="ti ti-users"></i>
        </div>
        <div class="module-name">Usuários</div>
        <div class="module-desc">Gestão de equipe e perfis</div>
    </a>

    <a href="/clientes" class="module-card blue" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(96,165,250,0.15); color:#60a5fa;">
            <i class="ti ti-user-circle"></i>
        </div>
        <div class="module-name">Clientes</div>
        <div class="module-desc"><%= stats.totalClientes %> cadastrado(s)</div>
    </a>

    <a href="/dispositivos" class="module-card amber" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(251,191,36,0.15); color:#fbbf24;">
            <i class="ti ti-device-laptop"></i>
        </div>
        <div class="module-name">Dispositivos</div>
        <div class="module-desc"><%= stats.dispositivosAtivos %> ativo(s) • QR Code</div>
    </a>

    <a href="/ordens" class="module-card purple" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(124,58,237,0.15); color:#a78bfa;">
            <i class="ti ti-tools"></i>
        </div>
        <div class="module-name">Ordens de Serviço</div>
        <div class="module-desc"><%= stats.osAbertas %> aberta(s)</div>
    </a>

    <a href="/estoque" class="module-card green" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(74,222,128,0.15); color:#4ade80;">
            <i class="ti ti-package"></i>
        </div>
        <div class="module-name">Estoque</div>
        <div class="module-desc"><%= stats.totalEstoque %> peça(s)</div>
    </a>

    <a href="/financeiro" class="module-card green" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(74,222,128,0.15); color:#4ade80;">
            <i class="ti ti-cash"></i>
        </div>
        <div class="module-name">Financeiro</div>
        <div class="module-desc">R$ <%= stats.receitaMes.toFixed(2).replace('.', ',') %> este mês</div>
    </a>

    <a href="/leads" class="module-card purple" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(124,58,237,0.15); color:#a78bfa;">
            <i class="ti ti-target-arrow"></i>
        </div>
        <div class="module-name">Leads</div>
        <div class="module-desc"><%= stats.totalLeads %> capturado(s)</div>
    </a>

    <a href="/ordens/kanban" class="module-card red" style="text-decoration:none;">
        <div class="module-icon" style="background:rgba(248,113,113,0.15); color:#f87171;">
            <i class="ti ti-layout-kanban"></i>
        </div>
        <div class="module-name">Kanban</div>
        <div class="module-desc">Visão visual das OS</div>
    </a>

</div>

<!-- WIDGETS INFERIORES -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin:0 30px 40px;" class="bottom-widgets">

    <!-- ÚLTIMAS OS REAIS -->
    <div style="background:#13121f; border:0.5px solid rgba(255,255,255,0.07); border-radius:12px; padding:18px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
            <div style="font-family:'Syne',sans-serif; font-size:14px; font-weight:700;">
                <i class="ti ti-clipboard-list" style="color: #a78bfa;"></i> Ordens recentes
            </div>
            <a href="/ordens" style="font-size:11px; color:#a78bfa; text-decoration:none;">Ver todas →</a>
        </div>

        <% if (ultimasOS.length === 0) { %>
            <div style="text-align:center; padding:30px; color:#cbd5e1; font-style:italic; font-size:13px;">
                <i class="ti ti-clipboard-off" style="font-size:28px;"></i>
                <p style="margin-top:8px;">Nenhuma OS cadastrada ainda.</p>
                <a href="/ordens/create" style="color:#a78bfa; font-size:12px;">+ Criar primeira OS</a>
            </div>
        <% } else { %>
            <% ultimasOS.forEach(os => {
                let statusCor = '#94a3b8';
                if (os.status === 'orcamento') statusCor = '#fbbf24';
                if (os.status === 'em_execucao') statusCor = '#a78bfa';
                if (os.status === 'pronta') statusCor = '#4ade80';
                if (os.status === 'entregue') statusCor = '#94a3b8';
                if (os.status === 'aprovada') statusCor = '#60a5fa';
            %>
                <a href="/ordens/<%= os.id %>" style="display:flex; align-items:center; gap:11px; padding:10px 0; border-bottom:0.5px solid rgba(255,255,255,0.07); text-decoration:none;">
                    <div style="width:8px; height:8px; border-radius:50%; background:<%= statusCor %>; box-shadow:0 0 8px <%= statusCor %>80;"></div>
                    <div style="flex:1;">
                        <div style="font-size:13px; font-weight:500; color:#fff;">
                            <span style="font-family:monospace; color:#a78bfa;"><%= os.numero_os %></span>
                            <span style="color:#64748b; margin-left:4px;"> • <%= os.dispositivo_tipo %></span>
                        </div>
                        <div style="font-size:11.5px; color:#94a3b8;">
                            <%= os.cliente_nome || 'Sem cliente' %>
                        </div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-size:11px; color:<%= statusCor %>; font-weight:600; text-transform:uppercase;">
                            <%= os.status.replace('_', ' ') %>
                        </div>
                        <div style="font-size:12px; color:#4ade80; font-weight:600; margin-top:2px;">
                            R$ <%= (os.valor_total || 0).toFixed(2).replace('.', ',') %>
                        </div>
                    </div>
                </a>
            <% }) %>
        <% } %>
    </div>

    <!-- ATIVIDADE RECENTE REAL -->
    <div style="background:#13121f; border:0.5px solid rgba(255,255,255,0.07); border-radius:12px; padding:18px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
            <div style="font-family:'Syne',sans-serif; font-size:14px; font-weight:700;">
                <i class="ti ti-activity" style="color: #4ade80;"></i> Atividade recente
            </div>
        </div>

        <% if (atividades.length === 0) { %>
            <div style="text-align:center; padding:30px; color:#cbd5e1; font-style:italic; font-size:13px;">
                <i class="ti ti-history-off" style="font-size:28px;"></i>
                <p style="margin-top:8px;">Sem atividades recentes.</p>
            </div>
        <% } else { %>
            <% atividades.forEach(a => { 
                const cores = {
                    purple: '#a78bfa',
                    blue: '#60a5fa',
                    amber: '#fbbf24',
                    green: '#4ade80'
                };
                const cor = cores[a.cor] || '#94a3b8';
                const tempo = new Date(a.tempo);
                const agora = new Date();
                const diffMs = agora - tempo;
                const diffMin = Math.floor(diffMs / 60000);
                const diffH = Math.floor(diffMin / 60);
                const diffD = Math.floor(diffH / 24);
                let tempoTexto;
                if (diffMin < 1) tempoTexto = 'agora';
                else if (diffMin < 60) tempoTexto = diffMin + ' min';
                else if (diffH < 24) tempoTexto = diffH + 'h';
                else tempoTexto = diffD + 'd';
            %>
                <div style="display:flex; align-items:center; gap:11px; padding:10px 0; border-bottom:0.5px solid rgba(255,255,255,0.07);">
                    <div style="width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:14px; background:<%= cor %>22; color:<%= cor %>;">
                        <i class="ti <%= a.icone %>"></i>
                    </div>
                    <div style="flex:1; font-size:12.5px; color:#fff;">
                        <%= a.texto %>
                    </div>
                    <div style="font-size:11px; color:#94a3b8;">
                        <%= tempoTexto %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>

</div>

<style>
@media (max-width: 768px) {
    .bottom-widgets {
        grid-template-columns: 1fr !important;
    }
}
</style>

