
<div class="content">

    <div class="page-header">
        <div>
            <h2>Novo Dispositivo</h2>
            <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                Cadastre um equipamento para reparo ou manutenção
            </span>
        </div>
        <a href="/dispositivos" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div class="form-container">

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="ti ti-alert-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/dispositivos" method="POST">

            <!-- ===== CLIENTE ===== -->
            <div class="form-group">
                <label for="cliente_id">Cliente *</label>
                <% if (clientes.length === 0) { %>
                    <div style="background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.3); padding: 12px; border-radius: 8px; color: #fbbf24; font-size: 13px;">
                        <i class="ti ti-alert-triangle"></i>
                        Nenhum cliente cadastrado. 
                        <a href="/clientes/create" style="color: #fbbf24; text-decoration: underline; font-weight: 600;">
                            Cadastrar cliente primeiro
                        </a>
                    </div>
                <% } else { %>
                    <select name="cliente_id" id="cliente_id" required>
                        <option value="">— Selecione o cliente —</option>
                        <% clientes.forEach(c => { %>
                            <option value="<%= c.id %>">
                                <%= c.nome %><%= c.telefone ? ' • ' + c.telefone : '' %>
                            </option>
                        <% }) %>
                    </select>
                <% } %>
            </div>

            <!-- ===== TIPO ===== -->
            <div class="form-group">
                <label for="tipo">Tipo do Dispositivo *</label>
                <select name="tipo" id="tipo" required>
                    <option value="">— Selecione —</option>
                    <option value="Notebook">💻 Notebook</option>
                    <option value="Desktop">🖥️ Desktop / PC</option>
                    <option value="All-in-One">🖥️ All-in-One</option>
                    <option value="Smartphone">📱 Smartphone</option>
                    <option value="Tablet">📱 Tablet</option>
                    <option value="Impressora">🖨️ Impressora</option>
                    <option value="Monitor">🖥️ Monitor</option>
                    <option value="Periférico">🖱️ Periférico</option>
                    <option value="Servidor">🗄️ Servidor</option>
                    <option value="Roteador">📡 Roteador / Rede</option>
                    <option value="Outro">⚙️ Outro</option>
                </select>
            </div>

            <!-- ===== MARCA + MODELO ===== -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;" class="form-row">
                <div class="form-group">
                    <label for="marca">Marca</label>
                    <input 
                        type="text" 
                        name="marca" 
                        id="marca" 
                        placeholder="Dell, Apple, HP, Samsung..."
                    >
                </div>

                <div class="form-group">
                    <label for="modelo">Modelo</label>
                    <input 
                        type="text" 
                        name="modelo" 
                        id="modelo" 
                        placeholder="Inspiron 15, MacBook Pro M2..."
                    >
                </div>
            </div>

            <!-- ===== NÚMERO DE SÉRIE ===== -->
            <div class="form-group">
                <label for="numero_serie">Número de Série</label>
                <input 
                    type="text" 
                    name="numero_serie" 
                    id="numero_serie" 
                    placeholder="SN-1234567890"
                >
            </div>

            <!-- ===== PROBLEMA RELATADO ===== -->
            <div class="form-group">
                <label for="problema_relato">Problema relatado pelo cliente</label>
                <textarea 
                    name="problema_relato" 
                    id="problema_relato" 
                    placeholder="Descreva o problema que o cliente relatou..."
                    rows="4"
                ></textarea>
            </div>

            <!-- ===== INFORMAÇÃO ===== -->
            <div style="background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.3); padding: 14px; border-radius: 8px; margin-bottom: 20px;">
                <div style="display: flex; align-items: center; gap: 10px; color: #a78bfa; font-size: 13px;">
                    <i class="ti ti-qrcode" style="font-size: 22px;"></i>
                    <div>
                        <strong>QR Code automático</strong>
                        <div style="color: rgba(255,255,255,0.6); font-size: 12px; margin-top: 2px;">
                            Um código único será gerado para rastreamento do dispositivo.
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== AÇÕES ===== -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Cadastrar Dispositivo
                </button>
                <a href="/dispositivos" class="btn btn-secondary">
                    <i class="ti ti-x"></i> Cancelar
                </a>
            </div>

        </form>

    </div>

</div>

<style>
@media (max-width: 600px) {
    .form-row {
        grid-template-columns: 1fr !important;
    }
}
</style>

