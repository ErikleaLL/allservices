
<div class="content">

    <div class="page-header">
        <div>
            <h2>Editar Peça</h2>
            <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                <%= peca.nome %>
            </span>
        </div>
        <a href="/estoque/<%= peca.id %>" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div class="form-container" style="max-width: 750px;">

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="ti ti-alert-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/estoque/<%= peca.id %>" method="POST">

            <!-- INFORMAÇÕES -->
            <div style="background: rgba(124,58,237,0.05); border: 1px solid rgba(124,58,237,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-package" style="color: #a78bfa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Informações da peça</h3>
                </div>

                <div class="form-group">
                    <label for="nome">Nome da peça *</label>
                    <input type="text" name="nome" id="nome" required value="<%= peca.nome %>">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="categoria_id">Categoria</label>
                        <select name="categoria_id" id="categoria_id">
                            <option value="">— Sem categoria —</option>
                            <% categorias.forEach(c => { %>
                                <option value="<%= c.id %>" <%= peca.categoria_id == c.id ? 'selected' : '' %>>
                                    <%= c.nome %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="fornecedor_id">Fornecedor</label>
                        <select name="fornecedor_id" id="fornecedor_id">
                            <option value="">— Sem fornecedor —</option>
                            <% fornecedores.forEach(f => { %>
                                <option value="<%= f.id %>" <%= peca.fornecedor_id == f.id ? 'selected' : '' %>>
                                    <%= f.nome %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                </div>
            </div>

            <!-- PREÇOS -->
            <div style="background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-cash" style="color: #4ade80; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Preços</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="preco_custo">Preço de custo (R$)</label>
                        <input type="number" step="0.01" min="0" 
                            name="preco_custo" id="preco_custo" 
                            value="<%= peca.preco_custo || 0 %>">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="preco_venda">Preço de venda (R$)</label>
                        <input type="number" step="0.01" min="0" 
                            name="preco_venda" id="preco_venda" 
                            value="<%= peca.preco_venda || 0 %>">
                    </div>

                </div>
            </div>

            <!-- ESTOQUE -->
            <div style="background: rgba(96,165,250,0.05); border: 1px solid rgba(96,165,250,0.15); border-radius: 12px; padding: 18px; margin-bottom: 22px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-stack" style="color: #60a5fa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Estoque</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="quantidade">Quantidade atual</label>
                        <input type="number" min="0" 
                            name="quantidade" id="quantidade" 
                            value="<%= peca.quantidade %>">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="estoque_minimo">Estoque mínimo</label>
                        <input type="number" min="0" 
                            name="estoque_minimo" id="estoque_minimo" 
                            value="<%= peca.estoque_minimo %>">
                    </div>

                </div>

                <div style="background: rgba(251,191,36,0.1); padding: 10px 14px; border-radius: 8px; margin-top: 14px; font-size: 12px; color: #fbbf24;">
                    <i class="ti ti-alert-triangle"></i>
                    <strong>Dica:</strong> Para entradas/saídas use a <strong>tela de detalhes</strong> (mantém histórico).
                </div>
            </div>

            <!-- AÇÕES -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Salvar Alterações
                </button>
                <a href="/estoque/<%= peca.id %>" class="btn btn-secondary">
                    <i class="ti ti-x"></i> Cancelar
                </a>
            </div>

        </form>

    </div>

</div>

<style>
@media (max-width: 700px) {
    .grid-2 { grid-template-columns: 1fr !important; }
}
</style>

