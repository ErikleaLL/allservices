
<div class="content">

    <div class="page-header">
        <div>
            <h2>Fornecedores</h2>
            <span style="color: #94a3b8; font-size: 13px;">
                Empresas que fornecem peças
            </span>
        </div>
        <a href="/estoque" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 380px; gap: 20px;" class="forn-grid">

        <!-- LISTA -->
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Fornecedor</th>
                        <th>Contato</th>
                        <th>Peças</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (fornecedores.length === 0) { %>
                        <tr>
                            <td colspan="4" class="empty">
                                <i class="ti ti-truck" style="font-size: 32px; opacity: 0.3;"></i>
                                <p style="margin-top: 10px;">Nenhum fornecedor cadastrado.</p>
                            </td>
                        </tr>
                    <% } else { %>
                        <% fornecedores.forEach(f => { %>
                            <tr>
                                <td>
                                    <strong><%= f.nome %></strong>
                                    <% if (f.cnpj) { %>
                                        <div style="font-size: 11px; color: #94a3b8; margin-top: 2px;">
                                            CNPJ: <%= f.cnpj %>
                                        </div>
                                    <% } %>
                                </td>
                                <td style="font-size: 12.5px; color: #475569;">
                                    <% if (f.telefone) { %>
                                        <div><i class="ti ti-phone"></i> <%= f.telefone %></div>
                                    <% } %>
                                    <% if (f.email) { %>
                                        <div style="margin-top: 2px;"><i class="ti ti-mail"></i> <%= f.email %></div>
                                    <% } %>
                                </td>
                                <td>
                                    <strong><%= f.total_pecas %></strong>
                                </td>
                                <td class="actions">
                                    <button onclick='editarFornecedor(<%- JSON.stringify(f) %>)' class="btn-sm btn-warning">
                                        <i class="ti ti-edit"></i>
                                    </button>
                                    <form action="/estoque/fornecedores/<%= f.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Excluir este fornecedor?')">
                                        <button type="submit" class="btn-sm btn-danger">
                                            <i class="ti ti-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- FORM -->
        <div class="detail-card">
            <h3 id="formTituloF" style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">
                <i class="ti ti-plus" style="color: #a78bfa;"></i> Novo Fornecedor
            </h3>

            <form id="formFornecedor" action="/estoque/fornecedores" method="POST">
                <div class="form-group">
                    <label>Nome *</label>
                    <input type="text" name="nome" id="fNome" required placeholder="Nome da empresa">
                </div>

                <div class="form-group">
                    <label>CNPJ</label>
                    <input type="text" name="cnpj" id="fCnpj" placeholder="00.000.000/0001-00">
                </div>

                <div class="form-group">
                    <label>Telefone</label>
                    <input type="text" name="telefone" id="fTelefone" placeholder="(00) 00000-0000">
                </div>

                <div class="form-group">
                    <label>E-mail</label>
                    <input type="email" name="email" id="fEmail" placeholder="contato@fornecedor.com">
                </div>

                <div class="form-group">
                    <label>Endereço</label>
                    <textarea name="endereco" id="fEndereco" rows="2" placeholder="Endereço completo..."></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" style="width: 100%;">
                        <i class="ti ti-check"></i> Salvar
                    </button>
                    <button type="button" onclick="cancelarF()" class="btn btn-secondary" style="width: 100%; display: none;" id="btnCancelarF">
                        <i class="ti ti-x"></i> Cancelar
                    </button>
                </div>
            </form>
        </div>

    </div>

</div>

<script>
function editarFornecedor(f) {
    document.getElementById('formFornecedor').action = '/estoque/fornecedores/' + f.id;
    document.getElementById('fNome').value = f.nome || '';
    document.getElementById('fCnpj').value = f.cnpj || '';
    document.getElementById('fTelefone').value = f.telefone || '';
    document.getElementById('fEmail').value = f.email || '';
    document.getElementById('fEndereco').value = f.endereco || '';
    document.getElementById('formTituloF').innerHTML = '<i class="ti ti-edit" style="color: #fbbf24;"></i> Editando Fornecedor';
    document.getElementById('btnCancelarF').style.display = 'inline-flex';
    window.scrollTo(0, 0);
}

function cancelarF() {
    document.getElementById('formFornecedor').action = '/estoque/fornecedores';
    document.getElementById('formFornecedor').reset();
    document.getElementById('formTituloF').innerHTML = '<i class="ti ti-plus" style="color: #a78bfa;"></i> Novo Fornecedor';
    document.getElementById('btnCancelarF').style.display = 'none';
}
</script>

<style>
@media (max-width: 1024px) {
    .forn-grid { grid-template-columns: 1fr !important; }
}
</style>

