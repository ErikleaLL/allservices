
<div class="content">

    <div class="page-header">
        <div>
            <h2>Novo Lançamento</h2>
            <span style="color: #94a3b8; font-size: 13px;">
                Registrar uma receita ou despesa
            </span>
        </div>
        <a href="/financeiro" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div class="form-container" style="max-width: 800px;">

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="ti ti-alert-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/financeiro" method="POST" id="formFinanc">

            <!-- ===== TIPO ===== -->
            <div style="background: rgba(255,255,255,0.02); border: 0.5px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-arrows-up-down" style="color: #a78bfa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Tipo de lançamento</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;" class="grid-2">

                    <label style="display: block; cursor: pointer;">
                        <input type="radio" name="tipo" value="receita" 
                            <%= tipoPreSelecionado === 'receita' ? 'checked' : '' %> 
                            onchange="atualizarCategorias()" 
                            style="display: none;">
                        <div class="tipo-card receita" data-tipo="receita">
                            <i class="ti ti-arrow-up-circle" style="font-size: 24px;"></i>
                            <div style="font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; margin-top: 8px;">Receita</div>
                            <div style="font-size: 11px; opacity: 0.7; margin-top: 4px;">Dinheiro entrando</div>
                        </div>
                    </label>

                    <label style="display: block; cursor: pointer;">
                        <input type="radio" name="tipo" value="despesa" 
                            <%= tipoPreSelecionado === 'despesa' ? 'checked' : '' %>
                            onchange="atualizarCategorias()" 
                            style="display: none;">
                        <div class="tipo-card despesa" data-tipo="despesa">
                            <i class="ti ti-arrow-down-circle" style="font-size: 24px;"></i>
                            <div style="font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; margin-top: 8px;">Despesa</div>
                            <div style="font-size: 11px; opacity: 0.7; margin-top: 4px;">Dinheiro saindo</div>
                        </div>
                    </label>

                </div>
            </div>

            <!-- ===== DADOS ===== -->
            <div style="background: rgba(124,58,237,0.05); border: 1px solid rgba(124,58,237,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-file-text" style="color: #a78bfa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Informações</h3>
                </div>

                <div class="form-group">
                    <label for="descricao">Descrição *</label>
                    <input type="text" name="descricao" id="descricao" required 
                        placeholder="Ex: Venda SSD para cliente João">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="valor">Valor (R$) *</label>
                        <input type="number" step="0.01" min="0" 
                            name="valor" id="valor" required 
                            placeholder="0,00">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="categoria">Categoria</label>
                        <select name="categoria" id="categoria">
                            <option value="">— Sem categoria —</option>
                            <!-- Será populado pelo JS -->
                        </select>
                    </div>

                </div>
            </div>

            <!-- ===== DATAS E STATUS ===== -->
            <div style="background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-calendar" style="color: #4ade80; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Datas e status</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;" class="grid-3">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="data_vencimento">Vencimento</label>
                        <input type="date" name="data_vencimento" id="data_vencimento">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="status">Status</label>
                        <select name="status" id="status" onchange="togglePagamento()">
                            <option value="pendente">Pendente</option>
                            <option value="pago">Pago</option>
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;" id="grupoDataPgto" style="display: none;">
                        <label for="data_pagamento">Pago em</label>
                        <input type="date" name="data_pagamento" id="data_pagamento">
                    </div>

                </div>

                <div class="form-group" style="margin-top: 14px; margin-bottom: 0;">
                    <label for="forma_pagamento">Forma de pagamento</label>
                    <select name="forma_pagamento" id="forma_pagamento">
                        <option value="">— Selecione —</option>
                        <% FORMAS_PAGAMENTO.forEach(fp => { %>
                            <option value="<%= fp %>"><%= fp %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <!-- ===== VÍNCULOS ===== -->
            <div style="background: rgba(96,165,250,0.05); border: 1px solid rgba(96,165,250,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                    <i class="ti ti-link" style="color: #60a5fa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;">Vínculos (opcional)</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="cliente_id">Cliente</label>
                        <select name="cliente_id" id="cliente_id">
                            <option value="">— Nenhum —</option>
                            <% clientes.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.nome %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="fornecedor_id">Fornecedor</label>
                        <select name="fornecedor_id" id="fornecedor_id">
                            <option value="">— Nenhum —</option>
                            <% fornecedores.forEach(f => { %>
                                <option value="<%= f.id %>"><%= f.nome %></option>
                            <% }) %>
                        </select>
                    </div>

                </div>
            </div>

            <!-- ===== OBSERVAÇÕES ===== -->
            <div class="form-group">
                <label for="observacoes">Observações</label>
                <textarea name="observacoes" id="observacoes" rows="3" 
                    placeholder="Notas adicionais sobre este lançamento..."></textarea>
            </div>

            <!-- AÇÕES -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Salvar Lançamento
                </button>
                <a href="/financeiro" class="btn btn-secondary">
                    <i class="ti ti-x"></i> Cancelar
                </a>
            </div>

        </form>

    </div>

</div>

<style>
.tipo-card {
    padding: 18px;
    text-align: center;
    border: 2px solid rgba(15,23,42,0.06);
    border-radius: 12px;
    background: rgba(255,255,255,0.02);
    transition: all 0.2s ease;
    color: #64748b;
}

.tipo-card:hover {
    background: rgba(15,23,42,0.04);
}

input[type="radio"]:checked + .tipo-card.receita {
    background: rgba(74,222,128,0.15);
    border-color: #4ade80;
    color: #4ade80;
}

input[type="radio"]:checked + .tipo-card.despesa {
    background: rgba(248,113,113,0.15);
    border-color: #f87171;
    color: #f87171;
}

@media (max-width: 700px) {
    .grid-2 { grid-template-columns: 1fr !important; }
    .grid-3 { grid-template-columns: 1fr !important; }
}
</style>

<script>
const CATEGORIAS = <%- JSON.stringify(CATEGORIAS) %>;

function atualizarCategorias() {
    const tipo = document.querySelector('input[name="tipo"]:checked').value;
    const select = document.getElementById('categoria');
    select.innerHTML = '<option value="">— Sem categoria —</option>';
    
    if (CATEGORIAS[tipo]) {
        CATEGORIAS[tipo].forEach(cat => {
            const opt = document.createElement('option');
            opt.value = cat;
            opt.textContent = cat;
            select.appendChild(opt);
        });
    }
}

function togglePagamento() {
    const status = document.getElementById('status').value;
    const grupoData = document.getElementById('grupoDataPgto');
    const dataPgto = document.getElementById('data_pagamento');
    
    if (status === 'pago') {
        grupoData.style.display = 'block';
        if (!dataPgto.value) {
            dataPgto.value = new Date().toISOString().split('T')[0];
        }
    } else {
        grupoData.style.display = 'none';
    }
}

// Inicializar
atualizarCategorias();
togglePagamento();
</script>

