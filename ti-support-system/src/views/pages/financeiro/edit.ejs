
<div class="content">

    <div class="page-header">
        <div>
            <h2>Editar Lançamento</h2>
            <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                <%= lancamento.descricao %>
            </span>
        </div>
        <a href="/financeiro/<%= lancamento.id %>" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div class="form-container" style="max-width: 800px;">

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="ti ti-alert-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/financeiro/<%= lancamento.id %>" method="POST">

            <!-- TIPO -->
            <div style="background: rgba(255,255,255,0.02); border: 0.5px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">Tipo</h3>
                <div class="form-group" style="margin-bottom: 0;">
                    <select name="tipo" required>
                        <option value="receita" <%= lancamento.tipo === 'receita' ? 'selected' : '' %>>Receita</option>
                        <option value="despesa" <%= lancamento.tipo === 'despesa' ? 'selected' : '' %>>Despesa</option>
                    </select>
                </div>
            </div>

            <!-- INFORMAÇÕES -->
            <div style="background: rgba(124,58,237,0.05); border: 1px solid rgba(124,58,237,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">Informações</h3>

                <div class="form-group">
                    <label>Descrição *</label>
                    <input type="text" name="descricao" required value="<%= lancamento.descricao %>">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Valor (R$) *</label>
                        <input type="number" step="0.01" min="0" name="valor" required value="<%= lancamento.valor %>">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Categoria</label>
                        <select name="categoria">
                            <option value="">— Sem categoria —</option>
                            <% [...CATEGORIAS.receita, ...CATEGORIAS.despesa].forEach(c => { %>
                                <option value="<%= c %>" <%= lancamento.categoria === c ? 'selected' : '' %>><%= c %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
            </div>

            <!-- DATAS -->
            <div style="background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">Datas e status</h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;" class="grid-3">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Vencimento</label>
                        <input type="date" name="data_vencimento" value="<%= lancamento.data_vencimento || '' %>">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Status</label>
                        <select name="status">
                            <option value="pendente" <%= lancamento.status === 'pendente' ? 'selected' : '' %>>Pendente</option>
                            <option value="pago" <%= lancamento.status === 'pago' ? 'selected' : '' %>>Pago</option>
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Pago em</label>
                        <input type="date" name="data_pagamento" value="<%= lancamento.data_pagamento || '' %>">
                    </div>
                </div>

                <div class="form-group" style="margin-top: 14px; margin-bottom: 0;">
                    <label>Forma de pagamento</label>
                    <select name="forma_pagamento">
                        <option value="">— Selecione —</option>
                        <% FORMAS_PAGAMENTO.forEach(fp => { %>
                            <option value="<%= fp %>" <%= lancamento.forma_pagamento === fp ? 'selected' : '' %>><%= fp %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <!-- VÍNCULOS -->
            <div style="background: rgba(96,165,250,0.05); border: 1px solid rgba(96,165,250,0.15); border-radius: 12px; padding: 18px; margin-bottom: 18px;">
                <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">Vínculos</h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;" class="grid-2">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Cliente</label>
                        <select name="cliente_id">
                            <option value="">— Nenhum —</option>
                            <% clientes.forEach(c => { %>
                                <option value="<%= c.id %>" <%= lancamento.cliente_id == c.id ? 'selected' : '' %>><%= c.nome %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Fornecedor</label>
                        <select name="fornecedor_id">
                            <option value="">— Nenhum —</option>
                            <% fornecedores.forEach(f => { %>
                                <option value="<%= f.id %>" <%= lancamento.fornecedor_id == f.id ? 'selected' : '' %>><%= f.nome %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Observações</label>
                <textarea name="observacoes" rows="3"><%= lancamento.observacoes || '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Salvar Alterações
                </button>
                <a href="/financeiro/<%= lancamento.id %>" class="btn btn-secondary">
                    <i class="ti ti-x"></i> Cancelar
                </a>
            </div>

        </form>

    </div>

</div>

<style>
@media (max-width: 700px) {
    .grid-2 { grid-template-columns: 1fr !important; }
    .grid-3 { grid-template-columns: 1fr !important; }
}
</style>

