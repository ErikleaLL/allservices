
<div class="content">

    <div class="page-header">
        <div>
            <h2>Fluxo de Caixa</h2>
            <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                Visão consolidada das finanças
            </span>
        </div>
        <a href="/financeiro" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- RESUMO GERAL -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-bottom: 25px;">

        <div style="background: linear-gradient(135deg, <%= resumo.saldo >= 0 ? 'rgba(74,222,128,0.15), rgba(74,222,128,0.03)' : 'rgba(248,113,113,0.15), rgba(248,113,113,0.03)' %>); border: 1px solid <%= resumo.saldo >= 0 ? 'rgba(74,222,128,0.3)' : 'rgba(248,113,113,0.3)' %>; border-radius: 12px; padding: 18px;">
            <div style="font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 6px;">
                <i class="ti ti-wallet"></i> Saldo realizado
            </div>
            <div style="font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 800; color: <%= resumo.saldo >= 0 ? '#4ade80' : '#f87171' %>;">
                R$ <%= resumo.saldo.toFixed(2).replace('.', ',') %>
            </div>
        </div>

        <div style="background: rgba(74,222,128,0.05); border: 0.5px solid rgba(74,222,128,0.2); border-radius: 12px; padding: 18px;">
            <div style="font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 6px;">
                <i class="ti ti-clock"></i> A receber
            </div>
            <div style="font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; color: #4ade80;">
                R$ <%= resumo.aReceber.toFixed(2).replace('.', ',') %>
            </div>
        </div>

        <div style="background: rgba(248,113,113,0.05); border: 0.5px solid rgba(248,113,113,0.2); border-radius: 12px; padding: 18px;">
            <div style="font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 6px;">
                <i class="ti ti-clock"></i> A pagar
            </div>
            <div style="font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; color: #f87171;">
                R$ <%= resumo.aPagar.toFixed(2).replace('.', ',') %>
            </div>
        </div>

        <div style="background: linear-gradient(135deg, rgba(124,58,237,0.12), rgba(124,58,237,0.02)); border: 1px solid rgba(124,58,237,0.3); border-radius: 12px; padding: 18px;">
            <div style="font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 6px;">
                <i class="ti ti-chart-pie"></i> Saldo projetado
            </div>
            <div style="font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; color: #a78bfa;">
                R$ <%= resumo.saldoProjetado.toFixed(2).replace('.', ',') %>
            </div>
        </div>

    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;" class="grid-2">

        <!-- PRÓXIMOS VENCIMENTOS -->
        <div class="detail-card">
            <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">
                <i class="ti ti-calendar-time" style="color: #fbbf24;"></i> Próximos 7 dias
            </h3>

            <% if (proximos.length === 0) { %>
                <div style="text-align: center; padding: 30px; color: rgba(255,255,255,0.3); font-style: italic; font-size: 13px;">
                    <i class="ti ti-circle-check" style="font-size: 32px;"></i>
                    <p style="margin-top: 8px;">Nada vence nos próximos dias.</p>
                </div>
            <% } else { %>
                <% proximos.forEach(p => { 
                    const cor = p.tipo === 'receita' ? '#4ade80' : '#f87171';
                %>
                    <a href="/financeiro/<%= p.id %>" style="display: block; text-decoration: none; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div style="flex: 1;">
                                <div style="font-size: 13px; color: #fff; font-weight: 500;"><%= p.descricao %></div>
                                <div style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px;">
                                    Vence em <%= new Date(p.data_vencimento + 'T00:00:00').toLocaleDateString('pt-BR') %>
                                </div>
                            </div>
                            <strong style="color: <%= cor %>; font-size: 14px;">
                                R$ <%= p.valor.toFixed(2).replace('.', ',') %>
                            </strong>
                        </div>
                    </a>
                <% }) %>
            <% } %>
        </div>

        <!-- TOP CATEGORIAS -->
        <div class="detail-card">
            <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">
                <i class="ti ti-chart-bar" style="color: #a78bfa;"></i> Top categorias
            </h3>

            <% if (topCategorias.length === 0) { %>
                <div style="text-align: center; padding: 30px; color: rgba(255,255,255,0.3); font-style: italic; font-size: 13px;">
                    Sem dados de categorias.
                </div>
            <% } else { %>
                <% topCategorias.forEach(c => { 
                    const cor = c.tipo === 'receita' ? '#4ade80' : '#f87171';
                %>
                    <div style="padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                            <div style="font-size: 13px; color: #fff;">
                                <span style="background: <%= cor %>22; color: <%= cor %>; padding: 2px 7px; border-radius: 50px; font-size: 9px; font-weight: 700; text-transform: uppercase; margin-right: 6px;">
                                    <%= c.tipo %>
                                </span>
                                <%= c.categoria %>
                            </div>
                            <strong style="color: <%= cor %>; font-size: 13px;">
                                R$ <%= c.valor_total.toFixed(2).replace('.', ',') %>
                            </strong>
                        </div>
                        <div style="font-size: 11px; color: rgba(255,255,255,0.4);">
                            <%= c.total %> lançamento(s)
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

    </div>

</div>

<style>
@media (max-width: 1024px) {
    .grid-2 { grid-template-columns: 1fr !important; }
}
</style>

