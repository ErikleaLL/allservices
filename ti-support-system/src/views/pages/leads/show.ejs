
<div class="content">

    <div class="page-header">
        <div>
            <h2>Detalhes do Lead</h2>
            <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                Recebido em <%= new Date(lead.criado_em).toLocaleString('pt-BR') %>
            </span>
        </div>
        <a href="/leads" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 350px; gap: 20px;" class="lead-grid">

        <!-- ===== INFORMAÇÕES ===== -->
        <div class="detail-card">

            <div class="detail-row">
                <div class="detail-label">Nome:</div>
                <div class="detail-value"><strong><%= lead.nome %></strong></div>
            </div>

            <div class="detail-row">
                <div class="detail-label">E-mail:</div>
                <div class="detail-value">
                    <a href="mailto:<%= lead.email %>" style="color: #60a5fa;">
                        <%= lead.email %>
                    </a>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-label">WhatsApp:</div>
                <div class="detail-value">
                    <% if (lead.whatsapp) { %>
                        <a href="https://wa.me/55<%= lead.whatsapp.replace(/\D/g,'') %>" target="_blank" style="color: #4ade80;">
                            <i class="ti ti-brand-whatsapp"></i> <%= lead.whatsapp %>
                        </a>
                    <% } else { %>
                        <span style="color: rgba(255,255,255,0.3);">Não informado</span>
                    <% } %>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Empresa:</div>
                <div class="detail-value"><%= lead.empresa || '-' %></div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Interesse:</div>
                <div class="detail-value"><%= lead.interesse || '-' %></div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Origem:</div>
                <div class="detail-value">
                    <span style="background: rgba(124,58,237,0.15); color: #a78bfa; padding: 3px 10px; border-radius: 50px; font-size: 11px; font-weight: 600; text-transform: uppercase;">
                        <%= lead.origem %>
                    </span>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Status atual:</div>
                <div class="detail-value">
                    <span class="lead-status status-<%= lead.status %>">
                        <%= lead.status.replace('_', ' ') %>
                    </span>
                </div>
            </div>

            <% if (lead.mensagem) { %>
                <div class="detail-row" style="flex-direction: column; align-items: flex-start; border-bottom: none;">
                    <div class="detail-label" style="margin-bottom: 10px;">
                        <i class="ti ti-message" style="color: #a78bfa;"></i> Mensagem do lead:
                    </div>
                    <div style="background: rgba(124,58,237,0.05); border-left: 3px solid #7c3aed; padding: 14px 16px; border-radius: 8px; width: 100%; color: #fff; font-size: 14px; line-height: 1.6;">
                        <%= lead.mensagem %>
                    </div>
                </div>
            <% } %>

        </div>

        <!-- ===== AÇÕES ===== -->
        <div>

            <!-- ATUALIZAR STATUS -->
            <div class="detail-card">
                <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">
                    <i class="ti ti-flag" style="color: #a78bfa;"></i> Atualizar Status
                </h3>

                <form action="/leads/<%= lead.id %>/status" method="POST">

                    <div class="form-group">
                        <label>Novo status:</label>
                        <select name="status" required>
                            <option value="novo" <%= lead.status === 'novo' ? 'selected' : '' %>>🆕 Novo</option>
                            <option value="contatado" <%= lead.status === 'contatado' ? 'selected' : '' %>>📞 Contatado</option>
                            <option value="em_negociacao" <%= lead.status === 'em_negociacao' ? 'selected' : '' %>>💬 Em Negociação</option>
                            <option value="convertido" <%= lead.status === 'convertido' ? 'selected' : '' %>>✅ Convertido</option>
                            <option value="perdido" <%= lead.status === 'perdido' ? 'selected' : '' %>>❌ Perdido</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">
                        <i class="ti ti-refresh"></i> Atualizar
                    </button>
                </form>
            </div>

            <!-- AÇÕES RÁPIDAS -->
            <div class="detail-card">
                <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 14px;">
                    <i class="ti ti-bolt" style="color: #fbbf24;"></i> Ações rápidas
                </h3>

                <a href="mailto:<%= lead.email %>" class="btn btn-info" style="width: 100%; margin-bottom: 10px;">
                    <i class="ti ti-mail"></i> Enviar E-mail
                </a>

                <% if (lead.whatsapp) { %>
                    <a href="https://wa.me/55<%= lead.whatsapp.replace(/\D/g,'') %>" target="_blank" class="btn btn-success" style="width: 100%; margin-bottom: 10px;">
                        <i class="ti ti-brand-whatsapp"></i> Abrir WhatsApp
                    </a>
                <% } %>

                <form action="/leads/<%= lead.id %>/delete" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir este lead?')">
                    <button type="submit" class="btn btn-danger" style="width: 100%;">
                        <i class="ti ti-trash"></i> Excluir Lead
                    </button>
                </form>
            </div>

        </div>

    </div>

</div>

<style>
@media (max-width: 1024px) {
    .lead-grid { grid-template-columns: 1fr !important; }
}
</style>

