
<div class="content">

    <div class="page-header">
        <div>
            <h2>Nova Ordem de Serviço</h2>
            <span style="color: #94a3b8; font-size: 13px;">
                Preencha os dados do orçamento inicial
            </span>
        </div>
        <a href="/ordens" class="btn btn-secondary">
            <i class="ti ti-arrow-left"></i> Voltar
        </a>
    </div>

    <div class="form-container" style="max-width: 900px;">

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="ti ti-alert-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/ordens" method="POST" id="formOS">

            <!-- ===== SEÇÃO: VÍNCULOS ===== -->
            <div style="background: rgba(124,58,237,0.05); border: 1px solid rgba(124,58,237,0.15); border-radius: 12px; padding: 18px; margin-bottom: 22px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 15px;">
                    <i class="ti ti-link" style="color: #a78bfa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: #fff;">Vínculos</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;" class="grid-2">

                    <div class="form-group">
                        <label for="cliente_id">Cliente *</label>
                        <% if (clientes.length === 0) { %>
                            <div style="background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.3); padding: 10px; border-radius: 6px; color: #fbbf24; font-size: 12px;">
                                <a href="/clientes/create" style="color: #fbbf24; text-decoration: underline;">Cadastre um cliente primeiro</a>
                            </div>
                        <% } else { %>
                            <select name="cliente_id" id="cliente_id" required>
                                <option value="">— Selecione —</option>
                                <% clientes.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.nome %></option>
                                <% }) %>
                            </select>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <label for="dispositivo_id">Dispositivo *</label>
                        <% if (dispositivos.length === 0) { %>
                            <div style="background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.3); padding: 10px; border-radius: 6px; color: #fbbf24; font-size: 12px;">
                                <a href="/dispositivos/create" style="color: #fbbf24; text-decoration: underline;">Cadastre um dispositivo primeiro</a>
                            </div>
                        <% } else { %>
                            <select name="dispositivo_id" id="dispositivo_id" required>
                                <option value="">— Selecione —</option>
                                <% dispositivos.forEach(d => { %>
                                    <option value="<%= d.id %>" 
                                        <%= dispositivoPreSelecionado == d.id ? 'selected' : '' %>>
                                        <%= d.qr_code %> • <%= d.tipo %>
                                        <%= d.marca ? ' • ' + d.marca : '' %>
                                        <%= d.modelo ? ' ' + d.modelo : '' %>
                                    </option>
                                <% }) %>
                            </select>
                        <% } %>
                    </div>

                </div>

                <div class="form-group" style="margin-top: 12px; margin-bottom: 0;">
                    <label for="tecnico_id">Técnico responsável (opcional)</label>
                    <select name="tecnico_id" id="tecnico_id">
                        <option value="">— Não atribuído —</option>
                        <% tecnicos.forEach(t => { %>
                            <option value="<%= t.id %>"><%= t.nome %> (<%= t.role %>)</option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <!-- ===== SEÇÃO: DIAGNÓSTICO ===== -->
            <div style="background: rgba(96,165,250,0.05); border: 1px solid rgba(96,165,250,0.15); border-radius: 12px; padding: 18px; margin-bottom: 22px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 15px;">
                    <i class="ti ti-search" style="color: #60a5fa; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: #fff;">Diagnóstico técnico</h3>
                </div>

                <div class="form-group">
                    <label for="diagnostico">Diagnóstico</label>
                    <textarea name="diagnostico" id="diagnostico" rows="3" 
                        placeholder="Ex: HD com bad blocks, tela de LCD com defeito..."></textarea>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label for="descricao_servico">Serviço a ser executado</label>
                    <textarea name="descricao_servico" id="descricao_servico" rows="3" 
                        placeholder="Ex: Troca de HD por SSD 240GB + formatação..."></textarea>
                </div>
            </div>

            <!-- ===== SEÇÃO: VALORES ===== -->
            <div style="background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.15); border-radius: 12px; padding: 18px; margin-bottom: 22px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 15px;">
                    <i class="ti ti-cash" style="color: #4ade80; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: #fff;">Valores</h3>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;" class="grid-2">

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="valor_mao_obra">Valor da mão de obra (R$)</label>
                        <input type="number" step="0.01" min="0" 
                            name="valor_mao_obra" id="valor_mao_obra" 
                            placeholder="0,00" value="0">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="garantia_dias">Garantia (dias)</label>
                        <input type="number" min="0" 
                            name="garantia_dias" id="garantia_dias" 
                            value="90">
                    </div>

                </div>

                <div style="background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.2); padding: 10px 14px; border-radius: 8px; margin-top: 14px; font-size: 12px; color: #4ade80;">
                    <i class="ti ti-info-circle"></i>
                    As <strong>peças</strong> podem ser adicionadas depois, na tela de detalhes da OS.
                </div>
            </div>

            <!-- ===== SEÇÃO: PRAZOS E OBSERVAÇÕES ===== -->
            <div style="background: rgba(251,191,36,0.05); border: 1px solid rgba(251,191,36,0.15); border-radius: 12px; padding: 18px; margin-bottom: 22px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 15px;">
                    <i class="ti ti-calendar" style="color: #fbbf24; font-size: 18px;"></i>
                    <h3 style="font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: #fff;">Prazo e observações</h3>
                </div>

                <div class="form-group">
                    <label for="prazo_entrega">Prazo de entrega</label>
                    <input type="date" name="prazo_entrega" id="prazo_entrega">
                </div>

                <div class="form-group">
                    <label for="observacoes_publicas">
                        Observações para o cliente <span style="color: #94a3b8; font-weight: 400; font-size: 11px;">(visível na página pública)</span>
                    </label>
                    <textarea name="observacoes_publicas" id="observacoes_publicas" rows="2" 
                        placeholder="Ex: Aguardando peça da loja X. Previsão: 5 dias úteis."></textarea>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label for="observacoes_internas">
                        Observações internas <span style="color: #94a3b8; font-weight: 400; font-size: 11px;">(só você vê)</span>
                    </label>
                    <textarea name="observacoes_internas" id="observacoes_internas" rows="2" 
                        placeholder="Anotações internas do técnico..."></textarea>
                </div>
            </div>

            <!-- AÇÕES -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Criar Ordem de Serviço
                </button>
                <a href="/ordens" class="btn btn-secondary">
                    <i class="ti ti-x"></i> Cancelar
                </a>
            </div>

        </form>

    </div>

</div>

<style>
@media (max-width: 700px) {
    .grid-2 { grid-template-columns: 1fr !important; }
}
</style>

