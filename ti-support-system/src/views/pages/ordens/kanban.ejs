
<div class="content">

    <div class="page-header">
        <div>
            <h2>Visualização Kanban</h2>
            <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                Visão visual de todas as OS por status • Arraste horizontalmente para ver mais
            </span>
        </div>
        <div>
            <a href="/ordens" class="btn btn-secondary">
                <i class="ti ti-list"></i> Lista
            </a>
            <a href="/ordens/create" class="btn btn-primary">
                <i class="ti ti-plus"></i> Nova OS
            </a>
        </div>
    </div>

</div>

<div class="kanban-wrapper">
    <div class="kanban-board">

        <% Object.entries(STATUS_OS).forEach(([statusKey, info]) => { 
            const ordensColuna = colunas[statusKey] || [];
        %>

            <div class="kanban-coluna" style="border-top-color: <%= info.cor %>;">

                <div class="kanban-coluna-header">
                    <div class="kanban-header-content">
                        <div class="kanban-coluna-icone" style="background: <%= info.cor %>22; color: <%= info.cor %>;">
                            <i class="ti <%= info.icone %>"></i>
                        </div>
                        <div>
                            <div class="kanban-coluna-titulo" style="color: <%= info.cor %>;">
                                <%= info.label %>
                            </div>
                            <div class="kanban-coluna-count">
                                <%= ordensColuna.length %> ordem(ns)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="kanban-cards">
                    <% if (ordensColuna.length === 0) { %>
                        <div class="kanban-vazio">
                            <i class="ti ti-inbox kanban-vazio-icone"></i>
                            <div>Nenhuma OS</div>
                        </div>
                    <% } else { %>
                        <% ordensColuna.forEach(os => { %>
                            <a href="/ordens/<%= os.id %>" class="kanban-card">
                                
                                <div class="kanban-card-header">
                                    <span class="kanban-card-numero"><%= os.numero_os %></span>
                                    <span class="kanban-card-data">
                                        <%= new Date(os.criado_em).toLocaleDateString('pt-BR', {day: '2-digit', month: '2-digit'}) %>
                                    </span>
                                </div>

                                <div class="kanban-card-cliente">
                                    <%= os.cliente_nome || 'Sem cliente' %>
                                </div>

                                <div class="kanban-card-dispositivo">
                                    <i class="ti ti-device-laptop"></i>
                                    <%= os.dispositivo_tipo %>
                                    <% if (os.dispositivo_marca) { %>
                                        • <%= os.dispositivo_marca %>
                                    <% } %>
                                </div>

                                <div class="kanban-card-footer">
                                    <span class="kanban-card-prazo">
                                        <% if (os.prazo_entrega) { %>
                                            <i class="ti ti-calendar"></i>
                                            <%= new Date(os.prazo_entrega + 'T00:00:00').toLocaleDateString('pt-BR', {day: '2-digit', month: '2-digit'}) %>
                                        <% } else { %>
                                            <i class="ti ti-clock"></i> Sem prazo
                                        <% } %>
                                    </span>
                                    <strong class="kanban-card-valor">
                                        R$ <%= (os.valor_total || 0).toFixed(2).replace('.', ',') %>
                                    </strong>
                                </div>

                                <% if (os.tecnico_nome) { %>
                                    <div class="kanban-card-tecnico">
                                        <i class="ti ti-user"></i> <%= os.tecnico_nome %>
                                    </div>
                                <% } %>

                            </a>
                        <% }) %>
                    <% } %>
                </div>

            </div>

        <% }) %>

        <!-- Espaçador final pra dar respiro -->
        <div style="flex: 0 0 20px;"></div>

    </div>
</div>

