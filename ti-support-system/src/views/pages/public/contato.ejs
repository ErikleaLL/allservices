
<section class="hero" style="padding: 80px 0;">
    <div class="container hero-content">
        <span class="hero-badge">💬 Vamos conversar</span>
        <h1>Entre em <span class="highlight">contato</span></h1>
        <p>Preencha o formulário e nossa equipe entrará em contato para apresentar a plataforma.</p>
    </div>
</section>

<section class="section">
    <div class="container">

        <form action="/lead" method="POST" class="form-public">

            <div class="form-group">
                <label for="nome">Nome completo *</label>
                <input type="text" name="nome" id="nome" required placeholder="Seu nome">
            </div>

            <div class="form-group">
                <label for="email">E-mail *</label>
                <input type="email" name="email" id="email" required placeholder="seu@email.com">
            </div>

            <div class="form-group">
                <label for="whatsapp">WhatsApp</label>
                <input type="text" name="whatsapp" id="whatsapp" placeholder="(00) 00000-0000">
            </div>

            <div class="form-group">
                <label for="empresa">Empresa / Assistência</label>
                <input type="text" name="empresa" id="empresa" placeholder="Nome do seu negócio">
            </div>

            <div class="form-group">
                <label for="interesse">Qual seu interesse?</label>
                <select name="interesse" id="interesse">
                    <option value="">Selecione...</option>
                    <option value="conhecer">Quero conhecer a plataforma</option>
                    <option value="contratar">Quero contratar</option>
                    <option value="parceria">Quero ser parceiro / franquia</option>
                    <option value="duvidas">Tenho dúvidas</option>
                    <option value="outro">Outro</option>
                </select>
            </div>

            <div class="form-group">
                <label for="mensagem">Mensagem</label>
                <textarea name="mensagem" id="mensagem" placeholder="Conte mais sobre seu interesse..."></textarea>
            </div>

            <button type="submit">Enviar mensagem 🚀</button>

        </form>

    </div>
</section>

