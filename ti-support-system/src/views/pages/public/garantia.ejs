
<style>
.gar-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #0a0a0f 0%, #1e1b3a 50%, #0f0a1f 100%);
    padding: 30px 16px 50px;
    position: relative;
    overflow-x: hidden;
}

.gar-page::before {
    content: '';
    position: absolute;
    top: 5%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(74,222,128,0.2) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
}

.gar-page::after {
    content: '';
    position: absolute;
    bottom: 10%;
    left: -10%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(124,58,237,0.2) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
}

.gar-wrapper {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
}

.gar-logo {
    text-align: center;
    margin-bottom: 25px;
    color: #fff;
}

.gar-logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #f97316, #f59e0b);
    border-radius: 12px;
    font-size: 24px;
    margin-bottom: 10px;
    box-shadow: 0 8px 25px rgba(249,115,22,0.4);
}

.gar-logo-text {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.03em;
}

.gar-logo-text strong { color: #f97316; }

/* CARD DE STATUS DA GARANTIA */
.gar-status-card {
    background: var(--status-bg);
    border: 2px solid var(--status-cor);
    border-radius: 20px;
    padding: 32px 28px;
    color: #fff;
    box-shadow: 0 25px 80px rgba(0,0,0,0.4);
    margin-bottom: 18px;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.gar-status-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, var(--status-cor)15 0%, transparent 60%);
    pointer-events: none;
}

.gar-status-icone {
    position: relative;
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--status-cor), var(--status-cor-dark));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 44px;
    margin: 0 auto 18px;
    box-shadow: 0 12px 35px var(--status-cor-shadow);
    animation: pulse-glow 2.5s ease-in-out infinite;
}

@keyframes pulse-glow {
    0%, 100% { box-shadow: 0 12px 35px var(--status-cor-shadow), 0 0 0 0 var(--status-cor-shadow); }
    50% { box-shadow: 0 12px 35px var(--status-cor-shadow), 0 0 0 18px transparent; }
}

.gar-status-label {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 2.5px;
    margin-bottom: 8px;
    font-weight: 700;
    position: relative;
}

.gar-status-titulo {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: var(--status-cor);
    position: relative;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 10px;
}

.gar-status-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.75);
    position: relative;
    font-weight: 500;
}

.gar-status-sub strong {
    color: var(--status-cor);
    font-weight: 800;
}

/* CARD PRINCIPAL */
.gar-card {
    background: rgba(19, 18, 31, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 28px 25px;
    color: #fff;
    box-shadow: 0 25px 80px rgba(0,0,0,0.4);
    margin-bottom: 18px;
}

.gar-card-titulo {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.gar-codigo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Geist Mono', monospace;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.3);
    color: #c4b5fd;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 18px;
    letter-spacing: 1px;
}

/* INFO ROWS */
.gar-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    gap: 15px;
}

.gar-info-row:last-child {
    border-bottom: none;
}

.gar-info-label {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 600;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.gar-info-value {
    font-size: 14px;
    color: #fff;
    font-weight: 600;
    text-align: right;
    word-break: break-word;
}

/* PEÇAS */
.gar-pecas-lista {
    background: rgba(255,255,255,0.03);
    border-radius: 12px;
    padding: 14px 16px;
    margin-top: 10px;
}

.gar-peca-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 13px;
}

.gar-peca-item:last-child {
    border-bottom: none;
}

.gar-peca-nome {
    color: #fff;
    font-weight: 500;
}

.gar-peca-qtd {
    color: rgba(255,255,255,0.5);
    font-size: 11px;
}

/* SERVIÇO */
.gar-servico-box {
    background: rgba(124,58,237,0.08);
    border-left: 3px solid #a78bfa;
    padding: 14px 16px;
    border-radius: 8px;
    margin-top: 10px;
    color: #fff;
    font-size: 14px;
    line-height: 1.6;
}

/* RODAPÉ */
.gar-rodape {
    text-align: center;
    padding: 20px;
    color: rgba(255,255,255,0.4);
    font-size: 12px;
}

.gar-rodape-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
}

.gar-rodape-badge.ativa {
    background: rgba(74,222,128,0.1);
    border: 1px solid rgba(74,222,128,0.3);
    color: #4ade80;
}

.gar-rodape-badge.vencida {
    background: rgba(248,113,113,0.1);
    border: 1px solid rgba(248,113,113,0.3);
    color: #f87171;
}

@media (max-width: 480px) {
    .gar-card { padding: 22px 18px; }
    .gar-status-titulo { font-size: 26px; }
    .gar-status-icone { width: 75px; height: 75px; font-size: 36px; }
    .gar-info-row { flex-direction: column; align-items: flex-start; gap: 6px; }
    .gar-info-value { text-align: left; }
}
</style>

<%
    let statusCor, statusCorDark, statusCorShadow, statusBg, statusIcone, statusLabel, statusTitulo, statusSub;
    
    if (garantiaAtiva) {
        statusCor = '#4ade80';
        statusCorDark = '#22c55e';
        statusCorShadow = 'rgba(74,222,128,0.4)';
        statusBg = 'linear-gradient(135deg, rgba(74,222,128,0.15), rgba(74,222,128,0.05))';
        statusIcone = 'ti-shield-check';
        statusLabel = 'Status da garantia';
        statusTitulo = 'Garantia Ativa';
        statusSub = 'Restam <strong>' + diasRestantes + ' dias</strong> de garantia';
    } else {
        statusCor = '#f87171';
        statusCorDark = '#dc2626';
        statusCorShadow = 'rgba(248,113,113,0.4)';
        statusBg = 'linear-gradient(135deg, rgba(248,113,113,0.15), rgba(248,113,113,0.05))';
        statusIcone = 'ti-shield-x';
        statusLabel = 'Status da garantia';
        statusTitulo = 'Garantia Vencida';
        statusSub = 'Esta peça não está mais coberta pela garantia';
    }
%>

<div class="gar-page" style="--status-cor: <%= statusCor %>; --status-cor-dark: <%= statusCorDark %>; --status-cor-shadow: <%= statusCorShadow %>; --status-bg: <%= statusBg %>;">
    <div class="gar-wrapper">

        <!-- LOGO TOPO -->
        <div class="gar-logo">
            <div class="gar-logo-icon">⚡</div>
            <div class="gar-logo-text">All<strong>services</strong></div>
        </div>

        <!-- STATUS DA GARANTIA -->
        <div class="gar-status-card">
            <div class="gar-status-icone">
                <i class="ti <%= statusIcone %>"></i>
            </div>
            <div class="gar-status-label"><%= statusLabel %></div>
            <div class="gar-status-titulo"><%= statusTitulo %></div>
            <div class="gar-status-sub"><%- statusSub %></div>
        </div>

        <!-- INFORMAÇÕES DO SERVIÇO -->
        <div class="gar-card">
            <div class="gar-card-titulo">
                <i class="ti ti-clipboard-check"></i> Comprovante de Serviço
            </div>

            <div style="text-align: center; margin-bottom: 20px;">
                <div class="gar-codigo">
                    <i class="ti ti-qrcode"></i> <%= ordem.qr_code_garantia %>
                </div>
            </div>

            <div class="gar-info-row">
                <div class="gar-info-label"><i class="ti ti-file-text"></i> OS</div>
                <div class="gar-info-value" style="font-family: 'Geist Mono', monospace;"><%= ordem.numero_os %></div>
            </div>

            <div class="gar-info-row">
                <div class="gar-info-label"><i class="ti ti-user"></i> Cliente</div>
                <div class="gar-info-value"><%= ordem.cliente_nome || '—' %></div>
            </div>

            <div class="gar-info-row">
                <div class="gar-info-label"><i class="ti ti-device-laptop"></i> Dispositivo</div>
                <div class="gar-info-value">
                    <%= ordem.dispositivo_tipo %>
                    <% if (ordem.dispositivo_marca) { %>
                        • <%= ordem.dispositivo_marca %>
                    <% } %>
                </div>
            </div>

            <% if (ordem.tecnico_nome) { %>
                <div class="gar-info-row">
                    <div class="gar-info-label"><i class="ti ti-tool"></i> Técnico</div>
                    <div class="gar-info-value"><%= ordem.tecnico_nome %></div>
                </div>
            <% } %>

            <div class="gar-info-row">
                <div class="gar-info-label"><i class="ti ti-calendar"></i> Realizado em</div>
                <div class="gar-info-value">
                    <% if (ordem.concluido_em) { %>
                        <%= new Date(ordem.concluido_em).toLocaleDateString('pt-BR') %>
                    <% } else { %>
                        <%= new Date(ordem.criado_em).toLocaleDateString('pt-BR') %>
                    <% } %>
                </div>
            </div>

            <div class="gar-info-row">
                <div class="gar-info-label"><i class="ti ti-shield"></i> Garantia</div>
                <div class="gar-info-value"><%= ordem.garantia_dias %> dias</div>
            </div>

            <% if (dataExpiracao) { %>
                <div class="gar-info-row">
                    <div class="gar-info-label"><i class="ti ti-calendar-event"></i> Válida até</div>
                    <div class="gar-info-value" style="color: <%= garantiaAtiva ? '#4ade80' : '#f87171' %>;">
                        <%= dataExpiracao.toLocaleDateString('pt-BR') %>
                    </div>
                </div>
            <% } %>

            <% if (ordem.valor_total > 0) { %>
                <div class="gar-info-row">
                    <div class="gar-info-label"><i class="ti ti-cash"></i> Valor pago</div>
                    <div class="gar-info-value" style="color: #4ade80; font-size: 16px;">
                        R$ <%= ordem.valor_total.toFixed(2).replace('.', ',') %>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- SERVIÇO REALIZADO -->
        <% if (ordem.solucao || ordem.descricao_servico) { %>
            <div class="gar-card">
                <div class="gar-card-titulo">
                    <i class="ti ti-tools"></i> Serviço Realizado
                </div>
                <div class="gar-servico-box">
                    <%= ordem.solucao || ordem.descricao_servico %>
                </div>
            </div>
        <% } %>

        <!-- PEÇAS USADAS -->
        <% if (ordem.pecas && ordem.pecas.length > 0) { %>
            <div class="gar-card">
                <div class="gar-card-titulo">
                    <i class="ti ti-package"></i> Peças Utilizadas
                </div>
                <div class="gar-pecas-lista">
                    <% ordem.pecas.forEach(p => { %>
                        <div class="gar-peca-item">
                            <div>
                                <div class="gar-peca-nome"><%= p.descricao %></div>
                                <div class="gar-peca-qtd"><%= p.quantidade %>x R$ <%= p.valor_unitario.toFixed(2).replace('.', ',') %></div>
                            </div>
                            <strong style="color: #4ade80;">
                                R$ <%= p.valor_total.toFixed(2).replace('.', ',') %>
                            </strong>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <!-- RODAPÉ -->
        <div class="gar-rodape">
            <div class="gar-rodape-badge <%= garantiaAtiva ? 'ativa' : 'vencida' %>">
                <i class="ti <%= garantiaAtiva ? 'ti-shield-check' : 'ti-shield-x' %>"></i>
                <%= garantiaAtiva ? 'Coberto pela garantia' : 'Fora da garantia' %>
            </div>
            <div>
                Allservices • Manutenção inteligente, gestão simples
            </div>
        </div>

    </div>
</div>

