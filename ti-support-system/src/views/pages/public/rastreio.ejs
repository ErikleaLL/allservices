
<style>
.rastreio-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #0a0a0f 0%, #1e1b3a 50%, #0f0a1f 100%);
    padding: 30px 16px 50px;
    position: relative;
    overflow-x: hidden;
}

/* Efeito de luz no fundo */
.rastreio-page::before {
    content: '';
    position: absolute;
    top: 10%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(124,58,237,0.25) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
}

.rastreio-page::after {
    content: '';
    position: absolute;
    bottom: 10%;
    left: -10%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(16,185,129,0.2) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
}

.rastreio-wrapper {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
}

/* LOGO TOPO */
.rastreio-logo {
    text-align: center;
    margin-bottom: 25px;
    color: #fff;
}

.rastreio-logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #f97316, #f59e0b);
    border-radius: 12px;
    font-size: 24px;
    margin-bottom: 10px;
    box-shadow: 0 8px 25px rgba(249,115,22,0.4);
}

.rastreio-logo-text {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
}

.rastreio-logo-text strong { color: #f97316; }

/* CARD PRINCIPAL */
.rastreio-card {
    background: rgba(19, 18, 31, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 30px 25px;
    color: #fff;
    box-shadow: 0 25px 80px rgba(0,0,0,0.4);
    margin-bottom: 18px;
}

/* HEADER */
.rastreio-header {
    text-align: center;
    margin-bottom: 25px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}

.rastreio-codigo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Syne', monospace;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.3);
    color: #c4b5fd;
    padding: 7px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 1.5px;
}

.rastreio-titulo {
    font-family: 'Syne', sans-serif;
    font-size: 26px;
    font-weight: 800;
    margin-bottom: 6px;
    color: #fff;
    letter-spacing: -0.5px;
}

.rastreio-subtitulo {
    color: rgba(255,255,255,0.55);
    font-size: 14px;
    line-height: 1.5;
}

/* STATUS ATUAL DESTAQUE */
.status-destaque {
    background: linear-gradient(135deg, var(--status-cor)25, var(--status-cor)05);
    border: 1px solid var(--status-cor);
    border-radius: 16px;
    padding: 28px 22px;
    text-align: center;
    margin-bottom: 28px;
    position: relative;
    overflow: hidden;
}

.status-destaque::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, var(--status-cor)10 0%, transparent 60%);
    pointer-events: none;
}

.status-icone-grande {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--status-cor), var(--status-cor-dark, var(--status-cor)));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 38px;
    margin: 0 auto 18px;
    box-shadow: 0 12px 35px var(--status-cor)50;
    animation: pulse-glow 2.5s ease-in-out infinite;
}

@keyframes pulse-glow {
    0%, 100% {
        box-shadow: 0 12px 35px var(--status-cor)50, 0 0 0 0 var(--status-cor)50;
    }
    50% {
        box-shadow: 0 12px 35px var(--status-cor)60, 0 0 0 15px var(--status-cor)00;
    }
}

.status-label-pequeno {
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 2.5px;
    margin-bottom: 8px;
    font-weight: 700;
    position: relative;
}

.status-label-grande {
    font-family: 'Syne', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: var(--status-cor);
    position: relative;
    letter-spacing: -0.5px;
}

/* TIMELINE */
.timeline-titulo {
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 14px;
    padding-left: 4px;
}

.timeline {
    background: rgba(255,255,255,0.02);
    border-radius: 14px;
    padding: 10px 18px;
    margin-bottom: 25px;
}

.timeline-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: relative;
}

.timeline-item:last-child { border-bottom: none; }

.timeline-item::before {
    content: '';
    position: absolute;
    left: 17px;
    top: 50px;
    bottom: -13px;
    width: 2px;
    background: rgba(255,255,255,0.05);
}

.timeline-item:last-child::before { display: none; }

.timeline-item.completo::before {
    background: linear-gradient(180deg, #4ade80, rgba(74,222,128,0.2));
}

.timeline-dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 15px;
    border: 2px solid;
    z-index: 1;
    position: relative;
    transition: all 0.3s ease;
}

.timeline-dot.completo {
    background: #4ade80;
    color: #052e16;
    border-color: #4ade80;
    box-shadow: 0 0 0 4px rgba(74,222,128,0.15);
}

.timeline-dot.atual {
    background: var(--status-cor);
    color: #fff;
    border-color: var(--status-cor);
    box-shadow: 0 0 0 4px var(--status-cor)30;
    animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

.timeline-dot.pendente {
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.3);
    border-color: rgba(255,255,255,0.1);
}

.timeline-info {
    flex: 1;
}

.timeline-nome {
    font-size: 14px;
    color: #fff;
    font-weight: 600;
    margin-bottom: 2px;
}

.timeline-item.pendente .timeline-nome {
    color: rgba(255,255,255,0.35);
    font-weight: 500;
}

.timeline-status {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
}

.timeline-item.completo .timeline-status {
    color: #4ade80;
}

.timeline-item.atual .timeline-status {
    color: var(--status-cor);
}

/* INFO GRID */
.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 18px;
}

.info-box {
    background: rgba(255,255,255,0.03);
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.2s ease;
}

.info-box:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
}

.info-icone {
    font-size: 16px;
    color: #a78bfa;
    margin-bottom: 6px;
}

.info-label {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
    font-weight: 700;
}

.info-value {
    font-size: 14px;
    color: #fff;
    font-weight: 600;
    word-break: break-word;
}

/* PROBLEMA */
.problema-box {
    background: linear-gradient(135deg, rgba(251,191,36,0.1), rgba(251,191,36,0.03));
    border: 1px solid rgba(251,191,36,0.3);
    padding: 16px 18px;
    border-radius: 12px;
    margin-top: 5px;
}

.problema-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
}

.problema-icone {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(251,191,36,0.2);
    color: #fbbf24;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
}

.problema-label {
    font-size: 11px;
    color: #fbbf24;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 700;
}

.problema-texto {
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    line-height: 1.6;
    padding-left: 36px;
}

/* RODAPÉ */
.rastreio-rodape {
    text-align: center;
    padding: 20px;
    color: rgba(255,255,255,0.4);
    font-size: 12px;
}

.rastreio-rodape-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(74,222,128,0.1);
    border: 1px solid rgba(74,222,128,0.3);
    color: #4ade80;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
}

/* RESPONSIVE */
@media (max-width: 480px) {
    .rastreio-card { padding: 22px 18px; }
    .rastreio-titulo { font-size: 22px; }
    .status-label-grande { font-size: 22px; }
    .status-icone-grande { width: 70px; height: 70px; font-size: 32px; }
    .info-grid { grid-template-columns: 1fr; }
    .timeline { padding: 5px 14px; }
}
</style>

<% const statusInfo = STATUS_LIST[dispositivo.status] || { label: dispositivo.status, cor: '#94a3b8', icone: 'ti-help' }; %>

<div class="rastreio-page" style="--status-cor: <%= statusInfo.cor %>;">
    <div class="rastreio-wrapper">

        <!-- LOGO TOPO -->
        <div class="rastreio-logo">
            <div class="rastreio-logo-icon">⚡</div>
            <div class="rastreio-logo-text">All<strong>services</strong></div>
        </div>

        <!-- CARD PRINCIPAL -->
        <div class="rastreio-card">

            <!-- HEADER -->
            <div class="rastreio-header">
                <div class="rastreio-codigo">
                    <i class="ti ti-qrcode"></i> <%= dispositivo.qr_code %>
                </div>
                <div class="rastreio-titulo">Acompanhe seu reparo</div>
                <div class="rastreio-subtitulo">
                    <%= dispositivo.tipo %>
                    <% if (dispositivo.marca || dispositivo.modelo) { %>
                        • <%= [dispositivo.marca, dispositivo.modelo].filter(Boolean).join(' ') %>
                    <% } %>
                </div>
            </div>

            <!-- STATUS ATUAL -->
            <div class="status-destaque">
                <div class="status-icone-grande">
                    <i class="ti <%= statusInfo.icone %>"></i>
                </div>
                <div class="status-label-pequeno">Status Atual</div>
                <div class="status-label-grande"><%= statusInfo.label %></div>
            </div>

            <!-- TIMELINE -->
            <div class="timeline-titulo">Linha do tempo do reparo</div>
            <div class="timeline">
                <% 
                    const ordemStatus = ['entrada','diagnostico','aguardando_pecas','em_reparo','pronto','entregue'];
                    const statusAtualIndex = ordemStatus.indexOf(dispositivo.status);
                %>

                <% ordemStatus.forEach((statusKey, index) => { 
                    const info = STATUS_LIST[statusKey];
                    let classe = 'pendente';
                    let statusTexto = 'Pendente';
                    if (index < statusAtualIndex) { classe = 'completo'; statusTexto = 'Concluído'; }
                    else if (index === statusAtualIndex) { classe = 'atual'; statusTexto = 'Em andamento'; }
                %>
                    <div class="timeline-item <%= classe %>">
                        <div class="timeline-dot <%= classe %>">
                            <% if (classe === 'completo') { %>
                                <i class="ti ti-check"></i>
                            <% } else { %>
                                <i class="ti <%= info.icone %>"></i>
                            <% } %>
                        </div>
                        <div class="timeline-info">
                            <div class="timeline-nome"><%= info.label %></div>
                            <div class="timeline-status"><%= statusTexto %></div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- INFORMAÇÕES -->
            <div class="info-grid">
                <div class="info-box">
                    <div class="info-icone"><i class="ti ti-user"></i></div>
                    <div class="info-label">Cliente</div>
                    <div class="info-value"><%= dispositivo.cliente_nome || 'Não informado' %></div>
                </div>

                <div class="info-box">
                    <div class="info-icone"><i class="ti ti-calendar"></i></div>
                    <div class="info-label">Entrada</div>
                    <div class="info-value">
                        <%= new Date(dispositivo.criado_em).toLocaleDateString('pt-BR') %>
                    </div>
                </div>
            </div>

            <!-- PROBLEMA -->
            <% if (dispositivo.problema_relato) { %>
                <div class="problema-box">
                    <div class="problema-header">
                        <div class="problema-icone">
                            <i class="ti ti-alert-triangle"></i>
                        </div>
                        <div class="problema-label">Problema relatado</div>
                    </div>
                    <div class="problema-texto"><%= dispositivo.problema_relato %></div>
                </div>
            <% } %>

        </div>

        <!-- RODAPÉ -->
        <div class="rastreio-rodape">
            <div class="rastreio-rodape-badge">
                <i class="ti ti-shield-check"></i> Atualização em tempo real
            </div>
            <div>
                Allservices • Manutenção inteligente, gestão simples
            </div>
        </div>

    </div>
</div>

